# =====================================================
# Video Analytics - Environment Configuration
# =====================================================
# Copy this file to .env and adjust paths for your system

# =====================================================
# STORAGE CONFIGURATION
# =====================================================
# Paths for video uploads, extracted frames, and vector database
VIDEO_STORAGE_PATH=./storage/videos
FRAME_STORAGE_PATH=./storage/frames
CHROMA_DB_PATH=./storage/chroma_db

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
# SQLite database for video metadata
DATABASE_URL=sqlite:///./storage/metadata.db

# =====================================================
# CLIP MODEL CONFIGURATION
# =====================================================
# HuggingFace model for semantic embeddings
CLIP_MODEL_ID=openai/clip-vit-base-patch32

# =====================================================
# VIDEO PROCESSING CONFIGURATION
# =====================================================
# Extract 1 frame per second (adjust for more/less detail)
TARGET_FPS=1

# YOLO model (ultra-nano: fast + accurate)
YOLO_MODEL=yolov8n.pt

# =====================================================
# RE-IDENTIFICATION THRESHOLDS
# =====================================================
# Cosine similarity threshold for CLIP re-ID matching
# Range: 0.0-1.0
# Higher = stricter (fewer false positives, may lose target)
# Lower = looser (more false positives, better at re-detection)
# Recommended: 0.55-0.75
REID_THRESHOLD=0.70
